            <button onClick={() => showToast("บันทึกผลการประเมินสำเร็จ")} className="w-full py-5 bg-indigo-600 text-white rounded-3xl font-black shadow-xl hover:bg-indigo-700 transition-all flex items-center justify-center gap-3 mt-10"><Save size={20}/> บันทึกการประเมินชุดนี้</button>
          </div>
        ) : <div className="py-20 text-center bg-slate-50 rounded-[2.5rem] border border-dashed border-slate-200"><ClipboardCheck className="mx-auto text-slate-200 mb-4" size={48} /><p className="text-slate-400 font-bold italic">กรุณาเลือกแบบฟอร์มเพื่อเริ่มการประเมิน</p></div>}
      </div>
    </div>
  );
}

function QAManager({ qaGroups, setQaGroups, showToast }) {
  const [showGroupForm, setShowGroupForm] = useState(false);
  const [editGroupId, setEditGroupId] = useState(null);
  const [newGroupName, setNewGroupName] = useState('');
  const [tempCriteria, setTempCriteria] = useState([]);
  const [newCrit, setNewCrit] = useState({ title: '', desc: '', weight: 0 });

  const addGroup = () => {
    if (!newGroupName || tempCriteria.length === 0) { showToast("ระบุชื่อและหัวข้ออย่างน้อย 1 หัวข้อ"); return; }
    const totalWeight = tempCriteria.reduce((a, b) => a + Number(b.weight), 0);
    if (totalWeight !== 100) { showToast(`ค่าน้ำหนักรวมต้องเป็น 100% (ขณะนี้: ${totalWeight}%)`); return; }

    if (editGroupId) {
      setQaGroups(qaGroups.map(g => g.id === editGroupId ? { ...g, name: newGroupName, criteria: tempCriteria } : g));
      showToast("แก้ไขสำเร็จ");
    } else {
      setQaGroups([...qaGroups, { id: Date.now(), name: newGroupName, criteria: tempCriteria }]);
      showToast("สร้างสำเร็จ");
    }
    resetForm();
  };

  const resetForm = () => {
    setShowGroupForm(false); setEditGroupId(null); setNewGroupName(''); setTempCriteria([]); setNewCrit({ title: '', desc: '', weight: 0 });
  };

  const handleEdit = (group) => {
    setEditGroupId(group.id); setNewGroupName(group.name); setTempCriteria(group.criteria); setShowGroupForm(true);
  };

  return (
    <div className="max-w-6xl mx-auto space-y-8 animate-in fade-in pb-20">
      <div className="flex justify-between items-center bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm">
        <div><h3 className="text-2xl font-black text-indigo-900">จัดการแบบฟอร์มประเมิน</h3><p className="text-xs text-slate-400 font-bold uppercase tracking-widest">Form Structure Management</p></div>
        <button onClick={() => {resetForm(); setShowGroupForm(true);}} className="px-8 py-4 bg-indigo-600 text-white rounded-2xl font-black shadow-lg hover:bg-indigo-700 transition-all flex items-center gap-2"><Plus size={20}/> สร้างแบบฟอร์มใหม่</button>
      </div>

      {showGroupForm && (
        <div className="bg-indigo-50/50 p-10 rounded-[3rem] border border-indigo-100 space-y-8 animate-in slide-in-from-top-4">
           <div className="flex justify-between items-center"><h4 className="text-xl font-black text-indigo-900">{editGroupId ? 'แก้ไขแบบฟอร์ม' : 'สร้างแบบฟอร์มใหม่'}</h4><button onClick={resetForm} className="p-2 hover:bg-white rounded-full text-slate-400"><X size={20}/></button></div>
           <FormGroup label="ชื่อกลุ่มแบบฟอร์ม"><input type="text" className="input-field" value={newGroupName} onChange={e => setNewGroupName(e.target.value)} /></FormGroup>
           <div className="bg-white p-8 rounded-[2rem] border border-indigo-100 space-y-6">
              <h5 className="font-black text-indigo-900 flex items-center gap-2"><Layers size={18}/> เพิ่มหัวข้อการประเมิน</h5>
              <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                 <input type="text" className="p-4 bg-slate-50 rounded-xl font-bold border border-transparent focus:border-indigo-400 outline-none text-sm" placeholder="หัวข้อ..." value={newCrit.title} onChange={e => setNewCrit({...newCrit, title: e.target.value})} />
                 <input type="text" className="p-4 bg-slate-50 rounded-xl font-bold border border-transparent focus:border-indigo-400 outline-none text-sm" placeholder="เกณฑ์..." value={newCrit.desc} onChange={e => setNewCrit({...newCrit, desc: e.target.value})} />
                 <div className="relative"><input type="number" className="w-full p-4 bg-slate-50 rounded-xl font-bold border border-transparent focus:border-indigo-400 outline-none text-sm pr-12" placeholder="Weight %" value={newCrit.weight} onChange={e => setNewCrit({...newCrit, weight: Number(e.target.value)})} /><span className="absolute right-4 top-1/2 -translate-y-1/2 font-black text-slate-300">%</span></div>
              </div>
              <button onClick={() => { if(newCrit.title && newCrit.weight > 0) { setTempCriteria([...tempCriteria, {...newCrit, id: Date.now()}]); setNewCrit({title:'', desc:'', weight:0}); } }} className="w-full py-3 bg-slate-900 text-white rounded-xl font-black text-xs">+ เพิ่มหัวข้อนี้</button>
              <div className="space-y-3 mt-6 border-t pt-6">{tempCriteria.map((c, idx) => (
                   <div key={c.id} className="p-4 bg-indigo-50/30 border border-indigo-100 rounded-2xl flex justify-between items-center">
                      <div className="flex gap-4 items-center"><span className="text-xs font-black text-indigo-400">#{idx+1}</span><div><div className="font-black text-sm text-slate-700">{c.title} <span className="text-indigo-600 ml-2">({c.weight}%)</span></div><div className="text-[10px] text-slate-400 font-bold italic">เกณฑ์: {c.desc}</div></div></div>
                      <button onClick={() => setTempCriteria(tempCriteria.filter(x => x.id !== c.id))} className="text-slate-300 hover:text-red-500"><Trash2 size={16}/></button>
                   </div>
              ))}</div>
              <div className="text-right font-black text-sm text-indigo-600">น้ำหนักรวม: {tempCriteria.reduce((a, b) => a + b.weight, 0)}% / 100%</div>
           </div>
           <button onClick={addGroup} className="w-full py-5 bg-indigo-600 text-white rounded-2xl font-black shadow-xl hover:bg-indigo-700 transition-all flex items-center justify-center gap-3"><Save size={20}/> {editGroupId ? 'บันทึกการแก้ไข' : 'ยืนยันการสร้าง'}</button>
        </div>
      )}

      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">{qaGroups.map(group => (
           <div key={group.id} className="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm relative group overflow-hidden">
              <div className="absolute top-0 right-0 p-4 flex gap-2">
                <button onClick={() => handleEdit(group)} className="p-2 bg-indigo-50 text-indigo-600 rounded-xl hover:bg-indigo-600 hover:text-white transition-all opacity-0 group-hover:opacity-100"><Edit2 size={16}/></button>
                <button onClick={() => setQaGroups(qaGroups.filter(g => g.id !== group.id))} className="p-2 bg-red-50 text-red-500 rounded-xl hover:bg-red-600 hover:text-white transition-all opacity-0 group-hover:opacity-100"><Trash2 size={16}/></button>
              </div>
              <h4 className="font-black text-xl text-indigo-900 mb-6 flex items-center gap-3"><FileText className="text-indigo-600"/> {group.name}</h4>
              <div className="space-y-4">{group.criteria.map(c => (
                   <div key={c.id} className="p-4 bg-slate-50 rounded-2xl border border-transparent"><div className="flex justify-between items-start mb-2"><span className="font-black text-sm text-slate-800">{c.title}</span><span className="text-[10px] font-black bg-white px-2 py-1 rounded-lg text-indigo-600 shadow-sm">{c.weight}%</span></div><p className="text-[10px] text-slate-400 font-bold leading-relaxed italic">เกณฑ์: {c.desc}</p></div>
              ))}</div>
           </div>
      ))}</div>
    </div>
  );
}

function SystemConfig({ categories, channels, supervisors, admins, onUpdateCats, onUpdateChans, onUpdateSups, onUpdateAdmins }) {
  const [newVal, setNewVal] = useState('');
  const [activeSub, setActiveSub] = useState('categories');
  const configs = { categories: { title: 'หมวดหมู่สคริปต์', list: categories, update: onUpdateCats, icon: <Layers size={20}/> }, channels: { title: 'ช่องทางรับเรื่อง', list: channels, update: onUpdateChans, icon: <Share2 size={20}/> }, supervisors: { title: 'รายชื่อ Supervisor', list: supervisors, update: onUpdateSups, icon: <UserCircle size={20}/> }, admins: { title: 'รายชื่อเจ้าหน้าที่ Admin', list: admins, update: onUpdateAdmins, icon: <Users size={20}/> } };
  const handleAdd = () => { if (!newVal) return; configs[activeSub].update([...configs[activeSub].list, newVal]); setNewVal(''); };
  const handleRemove = (item) => configs[activeSub].update(configs[activeSub].list.filter(i => i !== item));

  return (
    <div className="max-w-6xl mx-auto space-y-8 animate-in fade-in pb-20">
      <div className="flex gap-4 overflow-x-auto pb-4 custom-scrollbar">
        {Object.keys(configs).map(k => <button key={k} onClick={() => setActiveSub(k)} className={`px-6 py-4 rounded-2xl font-black text-sm whitespace-nowrap transition-all flex items-center gap-3 ${activeSub === k ? 'bg-indigo-600 text-white shadow-lg' : 'bg-white text-slate-400 hover:bg-indigo-50'}`}>{configs[k].icon} {configs[k].title}</button>)}
      </div>
      <div className="bg-white p-10 rounded-[3rem] border border-slate-100 shadow-sm">
        <h3 className="text-2xl font-black text-indigo-900 mb-8 flex items-center gap-3">{configs[activeSub].icon} {configs[activeSub].title}</h3>
        <div className="flex gap-3 mb-10"><input type="text" className="flex-1 input-field" placeholder={`เพิ่ม ${configs[activeSub].title}...`} value={newVal} onChange={e => setNewVal(e.target.value)} /><button onClick={handleAdd} className="px-8 bg-slate-900 text-white rounded-2xl font-black hover:bg-black transition-all">เพิ่มข้อมูล</button></div>
        <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">{configs[activeSub].list.map(item => <div key={item} className="p-4 bg-slate-50 rounded-2xl flex justify-between items-center group hover:bg-indigo-50 transition-all border border-slate-100"><span className="font-black text-sm text-slate-600 group-hover:text-indigo-600">{item}</span><button onClick={() => handleRemove(item)} className="p-1.5 text-slate-300 hover:text-red-500 transition-colors"><X size={14}/></button></div>)}</div>
      </div>
    </div>
  );
}

function HomeManager({ announcement, setAnnouncement, newsList, setNewsList, showToast }) {
  const [localAnnounce, setLocalAnnounce] = useState(announcement);
  const [newsForm, setNewsForm] = useState({ id: null, title: '', content: '', image: '', link: '', active: true });

  const handleSaveNews = () => {
    if (!newsForm.title || !newsForm.content) { showToast("กรอกข้อมูลให้ครบ"); return; }
    if (newsForm.id) setNewsList(prev => prev.map(n => n.id === newsForm.id ? newsForm : n));
    else setNewsList(prev => [{ ...newsForm, id: Date.now() }, ...prev]);
    showToast("บันทึกข่าวสำเร็จ"); setNewsForm({ id: null, title: '', content: '', image: '', link: '', active: true });
  };

  return (
    <div className="max-w-6xl mx-auto space-y-8 pb-20">
      <div className="bg-white p-10 rounded-[2.5rem] border border-slate-100 shadow-sm">
        <h3 className="text-2xl font-black text-indigo-900 mb-8 flex items-center gap-3"><Zap className="text-indigo-600"/> จัดการป้ายประกาศหลัก</h3>
        <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <FormGroup label="หัวข้อประกาศ"><input type="text" className="input-field" value={localAnnounce.title} onChange={e => setLocalAnnounce({...localAnnounce, title: e.target.value})} /></FormGroup>
          <FormGroup label="รายละเอียด"><input type="text" className="input-field" value={localAnnounce.content} onChange={e => setLocalAnnounce({...localAnnounce, content: e.target.value})} /></FormGroup>
        </div>
        <button onClick={() => { setAnnouncement(localAnnounce); showToast("อัปเดตสำเร็จ"); }} className="px-10 py-4 bg-indigo-600 text-white rounded-2xl font-black shadow-lg"><Save size={18}/> บันทึกประกาศ</button>
      </div>
      <div className="bg-white p-10 rounded-[2.5rem] border border-slate-100 shadow-sm">
        <h3 className="text-2xl font-black text-indigo-900 mb-8 flex items-center gap-3"><ImageIcon className="text-amber-500"/> ข่าวสารกิจกรรม</h3>
        <div className="space-y-6">
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            <FormGroup label="หัวข้อข่าว"><input type="text" className="input-field" value={newsForm.title} onChange={e => setNewsForm({...newsForm, title: e.target.value})} /></FormGroup>
            <FormGroup label="Image URL"><input type="text" className="input-field" value={newsForm.image} onChange={e => setNewsForm({...newsForm, image: e.target.value})} /></FormGroup>
          </div>
          <FormGroup label="เนื้อหาข่าว"><textarea rows={3} className="w-full p-5 bg-slate-50 rounded-2xl font-medium outline-none resize-none border border-transparent focus:border-indigo-400" value={newsForm.content} onChange={e => setNewsForm({...newsForm, content: e.target.value})} /></FormGroup>
          <button onClick={handleSaveNews} className="w-full py-5 bg-slate-900 text-white rounded-2xl font-black shadow-lg">บันทึกข่าวสาร</button>
        </div>
      </div>
      <div className="bg-white rounded-[2.5rem] border border-slate-200 overflow-hidden">
        <table className="w-full text-left">
          <thead className="bg-slate-50 text-[10px] font-black text-slate-400 uppercase tracking-widest"><tr className="px-8"><th className="px-8 py-5">รายการข่าว</th><th className="px-8 py-5">สถานะ</th><th className="px-8 py-5 text-right">จัดการ</th></tr></thead>
          <tbody className="divide-y divide-slate-100">{newsList.map(n => (
            <tr key={n.id}>
              <td className="px-8 py-4 font-black text-sm text-slate-700">{n.title}</td>
              <td className="px-8 py-4"><button onClick={() => setNewsList(prev => prev.map(x => x.id === n.id ? {...x, active: !x.active} : x))} className={`px-4 py-1.5 rounded-full text-[10px] font-black ${n.active ? 'bg-emerald-50 text-emerald-600' : 'bg-slate-100 text-slate-400'}`}>{n.active ? 'On Display' : 'Hidden'}</button></td>
              <td className="px-8 py-4 text-right flex justify-end gap-2"><button onClick={() => setNewsForm(n)} className="p-2 bg-indigo-50 text-indigo-600 rounded-xl"><Edit2 size={16}/></button><button onClick={() => setNewsList(prev => prev.filter(x => x.id !== n.id))} className="p-2 bg-red-50 text-red-500 rounded-xl"><Trash2 size={16}/></button></td>
            </tr>
          ))}</tbody>
        </table>
      </div>
    </div>
  );
}

function FormGroup({ label, icon, children }) {
  return (
    <div className="space-y-1.5 w-full">
      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">{label}</label>
      <div className="relative group">
        {icon && <div className="absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 pointer-events-none group-focus-within:text-indigo-600 transition-colors">{icon}</div>}
        {React.cloneElement(children, { className: `${children.props.className || ''} ${icon ? 'pl-11' : 'px-5'}` })}
      </div>
    </div>
  );
}

function DashboardOverview({ templates }) {
  const totalUsage = templates.reduce((acc, curr) => acc + curr.usage, 0);
  return (
    <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 animate-in fade-in">
      <StatCard label="Total Scripts" value={templates.length} sub="รายการในคลัง" icon={<Files size={20}/>} />
      <StatCard label="Total Usage" value={totalUsage.toLocaleString()} sub="ครั้งที่คัดลอก" icon={<MessageSquare size={20}/>} dark />
      <StatCard label="QA Audits" value="124" sub="ครั้งในเดือนนี้" icon={<ClipboardCheck size={20}/>} />
      <StatCard label="Accuracy" value="99.2%" sub="ความแม่นยำข้อมูล" icon={<Target size={20}/>} />
    </div>
  );
}

function StatCard({ label, value, sub, icon, dark }) {
  return (
    <div className={`p-6 rounded-[2rem] border shadow-sm ${dark ? 'bg-indigo-600 border-indigo-500 text-white' : 'bg-white border-slate-200 text-slate-900'}`}>
      <div className={`mb-4 w-10 h-10 rounded-xl flex items-center justify-center ${dark ? 'bg-white/20' : 'bg-indigo-50 text-indigo-600'}`}>{icon}</div>
      <p className={`text-[10px] font-black uppercase tracking-widest mb-1 ${dark ? 'text-indigo-100' : 'text-slate-400'}`}>{label}</p>
      <h2 className="text-3xl font-black">{value}</h2>
      <p className={`text-[10px] font-bold mt-1 ${dark ? 'text-indigo-200' : 'text-slate-400'}`}>{sub}</p>
    </div>
  );
}

function HistoryView({ logs, onDeleteLog }) {
  return (
    <div className="bg-white rounded-[2rem] border border-slate-200 overflow-hidden shadow-sm animate-in fade-in">
      <div className="p-8 border-b border-slate-100"><h3 className="font-black text-xl text-indigo-900">ประวัติการใช้งาน</h3></div>
      <div className="overflow-x-auto"><table className="w-full text-left"><thead><tr className="bg-slate-50 text-[10px] font-black text-slate-400 uppercase tracking-widest"><th className="px-8 py-5">วัน-เวลา</th><th className="px-6 py-5">กิจกรรม</th><th className="px-6 py-5">สคริปต์</th><th className="px-8 py-5 text-right">จัดการ</th></tr></thead><tbody className="divide-y divide-slate-50">{logs.map(log => (<tr key={log.id} className="text-sm hover:bg-slate-50/50 group transition-colors"><td className="px-8 py-5 text-slate-400 font-bold whitespace-nowrap">{log.date}</td><td className="px-6 py-5"><span className="px-3 py-1 rounded-full text-[10px] font-black uppercase bg-indigo-50 text-indigo-600">{log.action}</span></td><td className="px-6 py-5 font-bold text-slate-700">{log.title}</td><td className="px-8 py-5 text-right"><button onClick={() => onDeleteLog(log.id)} className="p-2 text-slate-200 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-all"><Trash2 size={16} /></button></td></tr>))}</tbody></table></div>
    </div>
  );
}

