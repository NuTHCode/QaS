function QAForm({ qaGroups, supervisors, admins, channels, showToast }) {
  const [selectedGroupId, setSelectedGroupId] = useState('');
  const [formData, setFormData] = useState({ supervisor: '', agent: '', evalDate: new Date().toISOString().split('T')[0], ticketDate: new Date().toISOString().split('T')[0], channel: '', ticketNo: 'C-' });
  const [scores, setScores] = useState({});
  const selectedGroup = qaGroups.find(g => g.id === selectedGroupId);

  const calculateTotal = () => {
    if (!selectedGroup) return 0;
    let total = 0;
    selectedGroup.criteria.forEach(c => {
      const score = scores[c.id] || 0;
      const percentage = score === 3 ? 1 : score === 2 ? 0.5 : 0;
      total += c.weight * percentage;
    });
    return total;
  };

  return (
    <div className="max-w-5xl mx-auto space-y-6 animate-in fade-in pb-20">
      <div className="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 p-8">
        <h3 className="text-2xl font-black text-indigo-900 mb-8">บันทึกผลการประเมินคุณภาพ</h3>
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
          <FormGroup label="เลือกกลุ่มแบบฟอร์ม" icon={<FileSearch size={18}/>}>
            <select className="input-field appearance-none" value={selectedGroupId} onChange={e => { setSelectedGroupId(e.target.value); setScores({}); }}>
               <option value="">-- โปรดเลือกแบบฟอร์ม --</option>
               {qaGroups.map(g => <option key={g.id} value={g.id}>{g.name}</option>)}
            </select>
          </FormGroup>
          <FormGroup label="Supervisor" icon={<UserCircle size={18}/>}>
            <select className="input-field appearance-none" value={formData.supervisor} onChange={e => setFormData({...formData, supervisor: e.target.value})}>
               <option value="">-- เลือก Supervisor --</option>
               {supervisors.map(s => <option key={s} value={s}>{s}</option>)}
            </select>
          </FormGroup>
          <FormGroup label="เจ้าหน้าที่ Admin" icon={<Users size={18}/>}>
            <select className="input-field appearance-none" value={formData.agent} onChange={e => setFormData({...formData, agent: e.target.value})}>
               <option value="">-- เลือกเจ้าหน้าที่ --</option>
               {admins.map(a => <option key={a} value={a}>{a}</option>)}
            </select>
          </FormGroup>
          <FormGroup label="วันที่ประเมิน" icon={<Calendar size={18}/>}>
            <input type="date" className="input-field" value={formData.evalDate} onChange={e => setFormData({...formData, evalDate: e.target.value})} />
          </FormGroup>
          <FormGroup label="วันที่ของใบงาน" icon={<Calendar size={18}/>}>
            <input type="date" className="input-field" value={formData.ticketDate} onChange={e => setFormData({...formData, ticketDate: e.target.value})} />
          </FormGroup>
          <FormGroup label="ช่องทางการรับเรื่อง">
            <select className="input-field appearance-none" value={formData.channel} onChange={e => setFormData({...formData, channel: e.target.value})}>
               <option value="">-- เลือกช่องทาง --</option>
               {channels.map(c => <option key={c} value={c}>{c}</option>)}
            </select>
          </FormGroup>
          <FormGroup label="เลขที่ใบงานอ้างอิง" icon={<Hash size={18}/>}>
            <input type="text" className="input-field" placeholder="C-0000000" value={formData.ticketNo} onChange={e => setFormData({...formData, ticketNo: e.target.value})} />
          </FormGroup>
        </div>

        {selectedGroup ? (
          <div className="space-y-6">
            <div className="flex items-center justify-between p-6 bg-slate-900 rounded-3xl text-white">
               <div><h4 className="font-black text-lg">{selectedGroup.name}</h4><p className="text-xs text-indigo-300 font-bold">กรุณาประเมินตามหัวข้อด้านล่าง</p></div>
               <div className="text-right"><div className="text-[10px] font-black uppercase text-slate-400">Total Score</div><div className="text-3xl font-black text-indigo-400">{calculateTotal().toFixed(2)}%</div></div>
            </div>
            <div className="space-y-4">
              {selectedGroup.criteria.map((c, idx) => (
                <div key={c.id} className="p-6 rounded-[2rem] bg-slate-50 border border-transparent hover:border-indigo-100 transition-all">
                  <div className="flex flex-col lg:flex-row justify-between gap-6">
                    <div className="flex-1 space-y-2">
                       <div className="flex items-center gap-3"><div className="w-8 h-8 bg-indigo-600 text-white rounded-lg flex items-center justify-center font-black text-xs">{idx + 1}</div><h5 className="font-black text-slate-800">{c.title} <span className="text-indigo-600 ml-2">({c.weight}%)</span></h5></div>
                       <div className="p-4 bg-white border border-slate-100 rounded-2xl text-xs font-medium text-slate-500 italic">เกณฑ์: {c.desc}</div>
