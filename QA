                      {[3, 2, 1].map(s => <button key={s} onClick={() => setScores({...scores, [c.id]: s})} className={`flex-1 lg:w-24 py-3 rounded-2xl text-xs font-black transition-all border-2 ${scores[c.id] === s ? 'bg-indigo-600 text-white border-indigo-600 shadow-lg' : 'bg-white text-slate-400 border-slate-100 hover:border-indigo-200'}`}>{s === 3 ? 'ผ่าน' : s === 2 ? 'พอใช้' : 'ปรับปรุง'}</button>)}
