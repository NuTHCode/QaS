import React, { useState, useMemo, useEffect, useRef } from 'react';
import { 
  LayoutDashboard, MessageSquare, Files, Users, Settings, 
  LogOut, Plus, Search, Bell, Copy, Edit2, Trash2, 
  CheckCircle2, Menu, X, Layers, Hash, Shield, Save, AlertCircle,
  History, RefreshCw, Flame, Tag, TrendingUp, BarChart3, Target, Zap,
  Share2, Home, ClipboardCheck, FileText, UserCircle, Newspaper, Trophy, Clock,
  ExternalLink, Eye, EyeOff, Image as ImageIcon, Link as LinkIcon, ChevronRight, ChevronLeft, Calendar, FileSearch, Filter, ChevronDown
} from 'lucide-react';

// --- INITIAL DATA ---
const INITIAL_CHANNELS = ["Facebook", "Line", "Shopee", "TikTok", "Lazada"];
const INITIAL_CATEGORIES = ["โปรโมชั่น", "แจ้งโอน", "ที่อยู่จัดส่ง", "คำถามบ่อย", "ทักทาย"];
const INITIAL_SUPERVISORS = ["Supervisor A", "Supervisor B", "Supervisor C"];
const INITIAL_ADMINS = ["Admin 01", "Admin 02", "Admin 03", "Admin 04"];

const INITIAL_TEMPLATES = [
  { id: 1, title: 'ทักทายลูกค้าใหม่', category: 'ทักทาย', channel: 'Facebook', content: 'สวัสดีครับ ยินดีต้อนรับสู่ร้านของเรา มีอะไรให้ช่วยไหมครับ?', keywords: 'สวัสดี, ทักทาย, ยินดีต้อนรับ', usage: 5250, createdAt: '2023-10-01 09:00:00' },
  { id: 2, title: 'แจ้งเลขพัสดุ', category: 'แจ้งโอน', channel: 'Line', content: 'ขอบคุณที่อุดหนุนครับ เลขพัสดุของคุณคือ [กรอกเลขพัสดุที่นี่]', keywords: 'เลขพัสดุ, ส่งของ, แทร็กกิ้ง', usage: 3400, createdAt: '2023-10-01 10:30:00' },
  { id: 3, title: 'แจ้งโปรโมชั่น 9.9', category: 'โปรโมชั่น', channel: 'Shopee', content: 'โปรโมชั่นสุดพิเศษ 9.9 ลดสูงสุด 50% เฉพาะวันนี้เท่านั้น!', keywords: 'ลดราคา, โปรโมชั่น, 9.9, แคมเปญ', usage: 1200, createdAt: '2023-10-02 14:15:00' },
];

const INITIAL_NEWS = [
  { id: 1, title: 'อัปเดตระบบเวอร์ชัน 2.5', content: 'พบกับฟีเจอร์จัดการแบบฟอร์มประเมินคุณภาพแบบใหม่ที่ใช้งานง่ายกว่าเดิม', image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=500', link: '#', active: true },
  { id: 2, title: 'เทคนิคการตอบแชทให้ปิดการขายไว', content: 'รวบรวมเทคนิคจาก Top Seller ที่จะทำให้คุณปิดการขายได้ภายใน 3 ประโยค', image: 'https://images.unsplash.com/photo-1551288049-bbbda536639a?q=80&w=500', link: '#', active: true },
];

const INITIAL_QA_GROUPS = [
  { 
    id: 'g1', 
    name: 'มาตรฐานการตอบแชททั่วไป', 
    criteria: [
      { id: 1, title: 'การใช้คำทักทาย', desc: 'ต้องมีการกล่าวทักทายตามช่วงเวลาที่เหมาะสม', weight: 20 },
      { id: 2, title: 'ความถูกต้องของข้อมูล', desc: 'ข้อมูลราคาสินค้าและสต็อกต้องถูกต้อง 100%', weight: 50 },
      { id: 3, title: 'การปิดการสนทนา', desc: 'ต้องกล่าวขอบคุณทุกครั้งก่อนจบงาน', weight: 30 },
    ]
  }
];

export default function App() {
  const [isLoggedIn, setIsLoggedIn] = useState(false);
  const [userRole, setUserRole] = useState('admin'); 
  const [activeTab, setActiveTab] = useState('home');
  const [sidebarOpen, setSidebarOpen] = useState(false);
  const [toast, setToast] = useState(null);

  // --- CORE STATES ---
  const [templates, setTemplates] = useState(INITIAL_TEMPLATES);
  const [categories, setCategories] = useState(INITIAL_CATEGORIES);
  const [channels, setChannels] = useState(INITIAL_CHANNELS);
  const [supervisors, setSupervisors] = useState(INITIAL_SUPERVISORS);
  const [admins, setAdmins] = useState(INITIAL_ADMINS);
  
  const [historyLogs, setHistoryLogs] = useState([]); 
  const [editItem, setEditItem] = useState(null);
  const [showModal, setShowModal] = useState(false);
  const [modalType, setModalType] = useState(null);

  const [newsList, setNewsList] = useState(INITIAL_NEWS);
  const [announcement, setAnnouncement] = useState({
    title: "ยินดีต้อนรับสู่ SmartQA Pro",
    content: "ระบบช่วยงานแชทครบวงจรที่มาพร้อมระบบประเมินผลอัจฉริยะ และการจัดการข่าวสารแบบเรียลไทม์"
  });

  const [qaGroups, setQaGroups] = useState(INITIAL_QA_GROUPS);

  // --- HELPER FUNCTIONS ---
  const handleTabChange = (tab) => {
    setActiveTab(tab);
    setSidebarOpen(false); 
  };

  const showToast = (msg) => {
    setToast(msg);
    setTimeout(() => setToast(null), 3000);
  };

  const copyToClipboard = (text, id) => {
    try {
      const textArea = document.createElement("textarea");
      textArea.value = text;
      textArea.style.position = "fixed";
      textArea.style.left = "-9999px";
      textArea.style.top = "-9999px";
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      const successful = document.execCommand('copy');
      document.body.removeChild(textArea);
      
      if (successful) {
        if (id) {
          const timestamp = new Date().toLocaleString('th-TH');
          const target = templates.find(t => t.id === id);
          setTemplates(prev => prev.map(t => t.id === id ? { ...t, usage: t.usage + 1 } : t));
          setHistoryLogs(prev => [{ 
            id: Date.now() + Math.random(), 
            templateId: id,
            title: target?.title || 'Unknown', 
            category: target?.category || 'General', 
            channel: target?.channel || 'All', 
            action: 'คัดลอกข้อความ', 
            date: timestamp, 
            user: 'Admin User' 
          }, ...prev]);
        }
        showToast("คัดลอกเรียบร้อย!");
      }
    } catch (err) {
      showToast("ไม่สามารถคัดลอกได้");
    }
  };

  const saveTemplate = (data) => {
    const now = new Date();
    const formattedDate = now.getFullYear() + "-" + 
                        String(now.getMonth() + 1).padStart(2, '0') + "-" + 
                        String(now.getDate()).padStart(2, '0') + " " + 
                        String(now.getHours()).padStart(2, '0') + ":" + 
                        String(now.getMinutes()).padStart(2, '0') + ":" + 
                        String(now.getSeconds()).padStart(2, '0');

    if (data.id) {
      setTemplates(prev => prev.map(t => t.id === data.id ? { ...data } : t));
      showToast("อัปเดตข้อมูลเรียบร้อย");
    } else {
      const newId = Date.now();
      const newTemplate = { ...data, id: newId, usage: 0, createdAt: formattedDate };
      setTemplates(prev => [newTemplate, ...prev]);
      showToast("เพิ่มข้อมูลใหม่เรียบร้อย");
    }
    setShowModal(false);
    setEditItem(null);
  };

  const deleteTemplate = (id) => {
    if (window.confirm(`ยืนยันการลบสคริปต์?`)) {
      setTemplates(prev => prev.filter(item => item.id !== id));
      showToast("ลบสคริปต์สำเร็จ");
    }
  };

  if (!isLoggedIn) return <AuthPage onLogin={(role) => { setIsLoggedIn(true); setUserRole(role); }} />;

  return (
    <div className="min-h-screen bg-slate-50 flex font-sans text-slate-900">
      {sidebarOpen && <div className="fixed inset-0 bg-slate-900/50 z-40 lg:hidden backdrop-blur-sm" onClick={() => setSidebarOpen(false)} />}
      
      <aside className={`fixed inset-y-0 left-0 z-50 w-64 bg-white border-r border-slate-200 transform transition-transform duration-300 lg:translate-x-0 lg:static lg:inset-0 ${sidebarOpen ? 'translate-x-0' : '-translate-x-full'}`}>
        <div className="h-full flex flex-col p-6">
          <div className="flex items-center gap-3 mb-10">
            <div className="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center shadow-lg">
              <Zap className="text-white" size={20} fill="currentColor" />
            </div>
            <span className="text-xl font-bold tracking-tight">SmartQA Pro</span>
          </div>
          <nav className="flex-1 space-y-1 overflow-y-auto pr-2 custom-scrollbar">
            <NavItem icon={<Home size={20}/>} label="หน้าหลัก" active={activeTab === 'home'} onClick={() => handleTabChange('home')} />
            <NavItem icon={<LayoutDashboard size={20}/>} label="แผงควบคุม" active={activeTab === 'dashboard'} onClick={() => handleTabChange('dashboard')} />
            <NavItem icon={<MessageSquare size={20}/>} label="ผู้ช่วย Smart Chat" active={activeTab === 'helper'} onClick={() => handleTabChange('helper')} />
            <NavItem icon={<ClipboardCheck size={20}/>} label="แบบฟอร์มประเมิน" active={activeTab === 'qa'} onClick={() => handleTabChange('qa')} />
            <NavItem icon={<History size={20}/>} label="ประวัติการใช้งาน" active={activeTab === 'history'} onClick={() => handleTabChange('history')} />
            
            {userRole === 'admin' && (
              <>
                <div className="pt-6 pb-2 px-3 text-[10px] font-bold text-slate-400 uppercase tracking-widest">Admin Control</div>
                <NavItem icon={<Newspaper size={20}/>} label="จัดการหน้าหลัก" active={activeTab === 'manage_home'} onClick={() => handleTabChange('manage_home')} />
                <NavItem icon={<FileSearch size={20}/>} label="จัดการแบบฟอร์ม" active={activeTab === 'manage_qa'} onClick={() => handleTabChange('manage_qa')} />
                <NavItem icon={<Files size={20}/>} label="จัดการสคริปต์" active={activeTab === 'manage'} onClick={() => handleTabChange('manage')} />
                <NavItem icon={<Settings size={20}/>} label="ตั้งค่าระบบ" active={activeTab === 'config'} onClick={() => handleTabChange('config')} />
              </>
            )}
          </nav>
          <div className="pt-6 border-t border-slate-100">
            <button onClick={() => setIsLoggedIn(false)} className="w-full flex items-center gap-3 px-4 py-2 text-slate-500 hover:text-red-600 transition-colors font-medium">
              <LogOut size={18} /> <span className="text-sm">ออกจากระบบ</span>
            </button>
          </div>
        </div>
      </aside>

      <main className="flex-1 flex flex-col min-w-0 h-screen overflow-hidden">
        <header className="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-6 shrink-0 z-30">
          <button className="lg:hidden p-2" onClick={() => setSidebarOpen(true)}><Menu size={24} /></button>
          <div className="text-sm font-bold text-indigo-600 bg-indigo-50 px-3 py-1 rounded-full uppercase tracking-widest">{activeTab.replace('_', ' ')}</div>
          <div className="flex items-center gap-3">
            <div className="text-right hidden sm:block">
              <div className="text-xs font-bold">Admin User</div>
              <div className="text-[10px] text-slate-400 uppercase">Management</div>
            </div>
            <div className="w-8 h-8 rounded-full bg-slate-200 border overflow-hidden">
              <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix" alt="avatar" />
            </div>
          </div>
        </header>

        <div className="flex-1 overflow-y-auto p-4 lg:p-8 custom-scrollbar">
          {activeTab === 'home' && (
            <HomeView 
              templates={templates} 
              announcement={announcement} 
              newsList={newsList} 
              onViewDetail={(item) => { setEditItem(item); setModalType('detail'); setShowModal(true); }}
              onCopy={copyToClipboard}
            />
          )}
          {activeTab === 'dashboard' && <DashboardOverview templates={templates} />}
          {activeTab === 'helper' && <HelperView templates={templates} categories={categories} channels={channels} onCopy={copyToClipboard} onViewDetail={(item) => { setEditItem(item); setModalType('detail'); setShowModal(true); }} />}
          {activeTab === 'qa' && <QAForm qaGroups={qaGroups} supervisors={supervisors} admins={admins} channels={channels} showToast={showToast} />}
          {activeTab === 'history' && <HistoryView logs={historyLogs} onDeleteLog={(id) => setHistoryLogs(prev => prev.filter(l => l.id !== id))} />}
          {activeTab === 'manage_home' && <HomeManager announcement={announcement} setAnnouncement={setAnnouncement} newsList={newsList} setNewsList={setNewsList} showToast={showToast} />}
          {activeTab === 'manage_qa' && <QAManager qaGroups={qaGroups} setQaGroups={setQaGroups} showToast={showToast} />}
          {activeTab === 'manage' && <TemplateManager templates={templates} categories={categories} channels={channels} onEdit={(t) => { setEditItem(t); setModalType('template'); setShowModal(true); }} onDelete={deleteTemplate} onAdd={() => { setEditItem(null); setModalType('template'); setShowModal(true); }} />}
          {activeTab === 'config' && <SystemConfig categories={categories} channels={channels} supervisors={supervisors} admins={admins} onUpdateCats={setCategories} onUpdateChans={setChannels} onUpdateSups={setSupervisors} onUpdateAdmins={setAdmins} />}
        </div>
      </main>

      {showModal && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm">
          <div className="bg-white rounded-3xl w-full max-w-lg shadow-2xl overflow-hidden animate-in zoom-in-95 duration-200">
            {modalType === 'template' && (
              <TemplateForm 
                item={editItem} 
                categories={categories} 
                channels={channels} 
                onSave={saveTemplate} 
                onClose={() => setShowModal(false)} 
              />
            )}
            {modalType === 'detail' && (
              <div className="p-8">
                <div className="flex justify-between items-center mb-6">
                  <h3 className="text-xl font-black text-indigo-900">รายละเอียดสคริปต์</h3>
                  <button onClick={() => setShowModal(false)} className="p-2 hover:bg-slate-100 rounded-full text-slate-400"><X size={20}/></button>
                </div>
                <div className="space-y-4">
                  <div className="grid grid-cols-2 gap-4">
                    <div>
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest">หมวดหมู่</label>
                      <p className="font-bold text-indigo-600">{editItem.category}</p>
                    </div>
                    <div>
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest">ช่องทาง</label>
                      <p className="font-bold text-indigo-600">{editItem.channel}</p>
                    </div>
                  </div>
                  <div>
                    <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest">หัวข้อ</label>
                    <p className="font-black text-slate-800">{editItem.title}</p>
                  </div>
                  <div>
                    <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest">เนื้อหา</label>
                    <div className="bg-slate-50 p-6 rounded-2xl text-slate-600 font-medium whitespace-pre-wrap leading-relaxed border border-slate-100 mt-2 text-sm">
                      {editItem.content}
                    </div>
                  </div>
                  {editItem.keywords && (
                    <div>
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest">Keywords</label>
                      <div className="flex flex-wrap gap-2 mt-1">
                        {editItem.keywords.split(',').map(kw => (
                          <span key={kw} className="bg-indigo-50 text-indigo-600 px-2 py-1 rounded text-[10px] font-bold">#{kw.trim()}</span>
                        ))}
                      </div>
                    </div>
                  )}
                  <button 
                    onClick={() => { copyToClipboard(editItem.content, editItem.id); setShowModal(false); }}
                    className="w-full py-4 bg-indigo-600 text-white rounded-2xl font-black flex items-center justify-center gap-2 hover:bg-indigo-700 transition-all shadow-lg"
                  >
                    <Copy size={18}/> คัดลอกสคริปต์นี้
                  </button>
                </div>
              </div>
            )}
          </div>
        </div>
      )}

      {toast && (
        <div className="fixed bottom-8 left-1/2 -translate-x-1/2 z-[200] bg-slate-900 text-white px-6 py-3 rounded-2xl shadow-xl flex items-center gap-3 animate-in slide-in-from-bottom-4">
          <CheckCircle2 size={18} className="text-emerald-400" />
          <span className="text-sm font-bold">{toast}</span>
        </div>
      )}
    </div>
  );
}

// --- COMPONENTS ---

function NavItem({ icon, label, active, onClick }) {
  return (
    <button onClick={onClick} className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 font-bold text-sm ${active ? 'bg-indigo-600 text-white shadow-lg' : 'text-slate-500 hover:bg-slate-100 hover:text-slate-900'}`}>
      {icon} <span>{label}</span>
    </button>
  );
}

function HomeView({ templates, announcement, newsList, onViewDetail, onCopy }) {
  const topTemplates = [...templates].sort((a, b) => b.usage - a.usage).slice(0, 3);
  const latestTemplates = [...templates].sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt)).slice(0, 3);
  const activeNews = newsList.filter(n => n.active);
  const [currentSlide, setCurrentSlide] = useState(0);

  useEffect(() => {
    const timer = setInterval(() => {
      setCurrentSlide(prev => activeNews.length > 0 ? (prev + 1) % activeNews.length : 0);
    }, 4000);
    return () => clearInterval(timer);
  }, [activeNews.length]);

  return (
    <div className="max-w-6xl mx-auto space-y-12 animate-in fade-in pb-20">
      <div className="bg-indigo-600 rounded-[2.5rem] p-10 text-white shadow-xl relative overflow-hidden">
        <div className="relative z-10">
          <h3 className="text-4xl font-black mb-4 tracking-tight leading-tight">{announcement.title}</h3>
          <p className="opacity-90 max-w-2xl text-lg font-medium leading-relaxed">{announcement.content}</p>
        </div>
        <Zap className="absolute right-[-20px] bottom-[-20px] text-white/10 w-64 h-64" fill="currentColor" />
      </div>

      {activeNews.length > 0 && (
        <section className="space-y-6">
          <h4 className="font-black text-2xl text-indigo-900 flex items-center gap-3 px-2">
            <Newspaper className="text-indigo-600" size={28} /> ข่าวสารและกิจกรรม
          </h4>
          <div className="relative overflow-hidden rounded-[2rem] bg-white border border-slate-100 shadow-sm h-48 md:h-56">
            <div className="flex transition-transform duration-700 h-full" style={{ transform: `translateX(-${currentSlide * 100}%)` }}>
              {activeNews.map(news => (
                <div key={news.id} className="min-w-full flex h-full">
                  <div className="w-1/3 h-full"><img src={news.image} className="w-full h-full object-cover" alt="news" /></div>
                  <div className="w-2/3 p-8 flex flex-col justify-center">
                    <h5 className="font-black text-xl mb-2 text-slate-800">{news.title}</h5>
                    <p className="text-slate-500 text-sm mb-4 line-clamp-2">{news.content}</p>
                    <a href={news.link} className="flex items-center gap-2 text-indigo-600 font-black text-xs hover:underline">อ่านเพิ่มเติม <ExternalLink size={14}/></a>
                  </div>
                </div>
              ))}
            </div>
            <div className="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-1.5">
              {activeNews.map((_, i) => <button key={i} onClick={() => setCurrentSlide(i)} className={`h-1.5 rounded-full transition-all ${currentSlide === i ? 'w-6 bg-indigo-600' : 'w-1.5 bg-slate-200'}`} />)}
            </div>
          </div>
        </section>
      )}

      <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <HomeCard title="สคริปต์ยอดนิยม" icon={<Trophy size={24} className="text-amber-500" />}>
          {topTemplates.map((s, index) => (
            <div key={s.id} className="p-5 bg-slate-50 rounded-3xl flex justify-between items-center group hover:bg-indigo-50 transition-all">
              <div className="flex items-center gap-5">
                <div className={`w-10 h-10 rounded-2xl flex items-center justify-center font-black text-sm ${index === 0 ? 'bg-amber-100 text-amber-600' : index === 1 ? 'bg-slate-200 text-slate-600' : 'bg-orange-100 text-orange-600'}`}>#{index + 1}</div>
                <div>
                  <div className="text-sm font-black text-slate-800">{s.title}</div>
                  <div className="text-[10px] text-slate-400 font-bold uppercase">{s.usage.toLocaleString()} ครั้ง</div>
                </div>
              </div>
              <button onClick={() => onCopy(s.content, s.id)} className="p-2 bg-white text-indigo-600 rounded-xl opacity-0 group-hover:opacity-100 shadow-sm"><Copy size={16}/></button>
            </div>
          ))}
        </HomeCard>

        <HomeCard title="สคริปต์เพิ่มล่าสุด" icon={<Clock size={24} className="text-indigo-500" />}>
          {latestTemplates.map((s) => (
            <div key={s.id} className="p-5 bg-white rounded-3xl border border-slate-100 flex justify-between items-center hover:shadow-md transition-all">
              <div className="flex items-center gap-4">
                <div className="w-10 h-10 bg-indigo-50 rounded-2xl flex items-center justify-center"><MessageSquare size={18} className="text-indigo-600"/></div>
                <div>
                  <div className="text-sm font-black text-slate-800">{s.title}</div>
                  <div className="text-[10px] text-slate-400 font-bold uppercase">{s.category}</div>
                </div>
              </div>
              <button onClick={() => onViewDetail(s)} className="text-[10px] font-black bg-indigo-50 text-indigo-600 px-4 py-2 rounded-xl hover:bg-indigo-600 hover:text-white transition-all">ดูรายละเอียด</button>
            </div>
          ))}
        </HomeCard>
      </div>
    </div>
  );
}

function HomeCard({ title, icon, children }) {
  return (
    <div className="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100">
      <h4 className="font-black text-xl mb-6 flex items-center gap-3 text-indigo-900 border-b border-slate-50 pb-4">{icon} {title}</h4>
      <div className="space-y-4">{children}</div>
    </div>
  );
}

function HelperView({ templates, categories, channels, onCopy, onViewDetail }) {
  const [search, setSearch] = useState('');
  const [filterChan, setFilterChan] = useState('');
  const [filterCat, setFilterCat] = useState('');

